NODE_ENV=development
PORT=3000

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=dogear
POSTGRES_PASSWORD=dogear
POSTGRES_DB=dogear

# Secret used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=changeme
JWT_EXPIRES_IN=7d

# Only needed the first time `npm run db:migrate` runs — it seeds the sole
# admin account (registration is closed). Safe to remove from .env afterward.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
